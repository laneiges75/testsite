{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "Customer consultation inquiry",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "content": { "type": "string", "description": "Inquiry content" },
        "status": { "type": "string", "enum": ["pending", "completed"], "description": "Processing status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "phone", "content", "status", "createdAt"]
    }
  },
  "firestore": {
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of consultation inquiries"
    }
  }
}
